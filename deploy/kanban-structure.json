{
  "board": {
    "title": "SmarterOS Revenue Pipeline",
    "description": "Lead → Cotización → Pago → Activo — Pipeline completo de facturación SmarterOS + OpenClaw",
    "properties": {
      "score": {"name": "Score", "type": "number", "options": []},
      "product": {"name": "Producto", "type": "select", "options": [
        {"id": "clawbot", "value": "CLAWBOT Kiosk", "color": "propColorRed"},
        {"id": "hosting", "value": "Hosting SmarterOS", "color": "propColorBlue"},
        {"id": "kiosk", "value": "Kiosk Setup", "color": "propColorGreen"},
        {"id": "subscription", "value": "SmarterOS Subscription", "color": "propColorPurple"},
        {"id": "openclaw", "value": "OpenClaw Agent", "color": "propColorOrange"}
      ]},
      "plan": {"name": "Plan", "type": "select", "options": [
        {"id": "starter", "value": "Starter (8.99€/mes)", "color": "propColorBlue"},
        {"id": "annual", "value": "Annual (6.99€/mes)", "color": "propColorGreen"},
        {"id": "biennial", "value": "Biennial (6.99€/mes)", "color": "propColorPurple"}
      ]},
      "price_uf": {"name": "Precio UF", "type": "number"},
      "price_clp": {"name": "Precio CLP", "type": "number"},
      "action": {"name": "Accion", "type": "select", "options": [
        {"id": "quote", "value": "Enviar cotizacion", "color": "propColorYellow"},
        {"id": "paylink", "value": "Enviar link pago", "color": "propColorGreen"},
        {"id": "activate", "value": "Activar servicio", "color": "propColorPurple"},
        {"id": "close", "value": "Cerrar agresivo", "color": "propColorRed"}
      ]},
      "paid": {"name": "Pagado", "type": "checkbox"},
      "telegram_chat": {"name": "Telegram Chat ID", "type": "text"}
    }
  },
  "columns": [
    {
      "title": "🔵 Lead Nuevo",
      "description": "Lead entrante por webhook, Telegram o scraping",
      "trigger": "new_lead",
      "color": "propColorBlue",
      "actions": ["score_lead", "send_welcome"]
    },
    {
      "title": "🟡 Cotizado",
      "description": "Cotizacion enviada con precio en UF + CLP",
      "trigger": "quote_sent",
      "color": "propColorYellow",
      "actions": ["send_payment_link", "start_followup"]
    },
    {
      "title": "🟠 Link Enviado",
      "description": "Link de pago enviado via Telegram/Email",
      "trigger": "payment_link_sent",
      "color": "propColorOrange",
      "actions": ["wait_payment", "reminder_24h"]
    },
    {
      "title": "✅ Pagado",
      "description": "Pago confirmado via MercadoPago/Flow.cl",
      "trigger": "payment_confirmed",
      "color": "propColorGreen",
      "actions": ["create_invoice", "activate_service", "send_confirmation"]
    },
    {
      "title": "🟢 Activo",
      "description": "Servicio activado y operando",
      "trigger": "service_active",
      "color": "propColorPurple",
      "actions": ["send_welcome_kit", "schedule_checkin"]
    },
    {
      "title": "❌ Perdido",
      "description": "Lead perdido — nurture sequence",
      "trigger": "lead_lost",
      "color": "propColorGray",
      "actions": ["nurture_sequence", "recheck_30d"]
    }
  ],
