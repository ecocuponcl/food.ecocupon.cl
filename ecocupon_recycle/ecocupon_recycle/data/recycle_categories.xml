<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default recycle categories -->
        <record id="cat_lata" model="recycle.category">
            <field name="name">Lata</field>
            <field name="icon">🥫</field>
            <field name="default_cashback">50</field>
            <field name="description">Latas de aluminio y acero</field>
            <field name="require_photo">True</field>
        </record>
        <record id="cat_botella" model="recycle.category">
            <field name="name">Botella Plástica</field>
            <field name="icon">🧴</field>
            <field name="default_cashback">75</field>
            <field name="description">Botellas PET y HDPE</field>
            <field name="require_photo">True</field>
        </record>
        <record id="cat_vidrio" model="recycle.category">
            <field name="name">Vidrio</field>
            <field name="icon">🍾</field>
            <field name="default_cashback">100</field>
            <field name="description">Botellas y frascos de vidrio</field>
            <field name="require_photo">True</field>
        </record>
        <record id="cat_carton" model="recycle.category">
            <field name="name">Cartón</field>
            <field name="icon">📦</field>
            <field name="default_cashback">30</field>
            <field name="description">Cajas y envases de cartón</field>
            <field name="require_photo">False</field>
        </record>
        <record id="cat_sixpack" model="recycle.category">
            <field name="name">Sixpack Cerveza</field>
            <field name="icon">🍺</field>
            <field name="default_cashback">150</field>
            <field name="description">Pack de 6 latas/botellas de cerveza</field>
            <field name="require_photo">True</field>
        </record>
    </data>
</odoo>
