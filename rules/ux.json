[
  {
    "id": "UX_01",
    "category": "ux",
    "name": "m\u00e1ximo 5 estados por flujo",
    "rule": "un flujo con m\u00e1s de 5 estados es inutilizable",
    "check": "workflow.states.length <= 5",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "Complejidad mata adopci\u00f3n"
  },
  {
    "id": "UX_02",
    "category": "ux",
    "name": "responsable visible",
    "rule": "cada tarea debe mostrar responsable claramente",
    "check": "task.owner_visible == true",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "Si no se ve qui\u00e9n, nadie lo hace"
  },
  {
    "id": "UX_03",
    "category": "ux",
    "name": "progreso visible",
    "rule": "el usuario debe ver progreso en tiempo real",
    "check": "progress_visible == true",
    "action": "warn",
    "severity": "medium",
    "weight": 0.04,
    "enabled": true,
    "phase": "post",
    "description": "Sin feedback visual, el usuario abandona"
  },
  {
    "id": "UX_04",
    "category": "ux",
    "name": "respuesta < 3 segundos",
    "rule": "respuesta al usuario debe ser < 3 segundos",
    "check": "metrics.response_time_ms < 3000",
    "action": "warn",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "3s es el l\u00edmite de paciencia humana"
  },
  {
    "id": "UX_05",
    "category": "ux",
    "name": "confirmaci\u00f3n antes de destructivo",
    "rule": "acciones destructivas requieren confirmaci\u00f3n expl\u00edcita",
    "check": "action.destructive == true \u2192 confirmed == true",
    "action": "require_confirmation",
    "severity": "critical",
    "weight": 0.08,
    "enabled": true,
    "phase": "pre",
    "description": "Nunca borrar sin confirmar"
  },
  {
    "id": "UX_06",
    "category": "ux",
    "name": "texto en idioma del usuario",
    "rule": "output debe estar en el idioma detectado del usuario",
    "check": "language == user.detected_language",
    "action": "warn",
    "severity": "low",
    "weight": 0.03,
    "enabled": true,
    "phase": "post",
    "description": "Espa\u00f1ol para Chile, ingl\u00e9s para dev"
  },
  {
    "id": "UX_07",
    "category": "ux",
    "name": "m\u00e1ximo 3 opciones por decisi\u00f3n",
    "rule": "par\u00e1lisis por an\u00e1lisis: m\u00e1ximo 3 opciones",
    "check": "decision.options.length <= 3",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "3 opciones es el sweet spot"
  },
  {
    "id": "UX_08",
    "category": "ux",
    "name": "error message comprensible",
    "rule": "mensajes de error deben ser comprensibles por humanos",
    "check": "error.is_human_readable == true",
    "action": "reject",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "Nunca mostrar stack trace al usuario"
  },
  {
    "id": "UX_09",
    "category": "ux",
    "name": "undo disponible",
    "rule": "acciones importantes deben tener undo",
    "check": "action.reversible == true || action.has_undo == true",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "El undo es la red de seguridad del usuario"
  },
  {
    "id": "UX_10",
    "category": "ux",
    "name": "mobile responsive",
    "rule": "todo output debe ser legible en m\u00f3vil",
    "check": "mobile_friendly == true",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "50%+ del tr\u00e1fico es m\u00f3vil"
