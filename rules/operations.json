[
  {
    "id": "OPS_00",
    "category": "operations",
    "name": "mandatory delegation",
    "rule": "si existe integraci\u00f3n posible \u2192 no ejecutar manual, delegar al sistema",
    "check": "available_integration != null \u2192 use_integration == true",
    "action": "force_delegation",
    "severity": "critical",
    "weight": 0.12,
    "enabled": true,
    "phase": "pre",
    "description": "CR\u00cdTICO: Si hay un agente/sistema que puede hacerlo, delegar. No responder texto."
  },
  {
    "id": "OPS_01B",
    "category": "operations",
    "name": "no passive mode",
    "rule": "el sistema no puede quedarse en respuesta sin acci\u00f3n",
    "check": "next_action != null",
    "action": "require_execution",
    "severity": "critical",
    "weight": 0.1,
    "enabled": true,
    "phase": "post",
    "description": "CR\u00cdTICO: Toda respuesta debe incluir siguiente acci\u00f3n ejecutable"
  },
  {
    "id": "OPS_02B",
    "category": "operations",
    "name": "always output action",
    "rule": "todo output debe incluir siguiente acci\u00f3n ejecutable con responsable",
    "check": "next_action != null && next_action.owner != null",
    "action": "require_execution",
    "severity": "critical",
    "weight": 0.1,
    "enabled": true,
    "phase": "post",
    "description": "CR\u00cdTICO: La acci\u00f3n debe tener owner asignado"
  },
  {
    "id": "OPS_01",
    "category": "operations",
    "name": "evaluar automatizaci\u00f3n si >3 pasos",
    "rule": "si proceso tiene m\u00e1s de 3 pasos \u2192 evaluar automatizaci\u00f3n",
    "check": "process.steps.length > 3 \u2192 suggest_automation == true",
    "action": "suggest_automation",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "Procesos largos deben automatizarse"
  },
  {
    "id": "OPS_02",
    "category": "operations",
    "name": "estados de flujo definidos",
    "rule": "todo flujo debe tener estados definidos",
    "check": "workflow.states != null && workflow.states.length >= 2",
    "action": "reject",
    "severity": "high",
    "weight": 0.063,
    "enabled": true,
    "phase": "post",
    "description": "Sin estados no hay workflow"
  },
  {
    "id": "OPS_03",
    "category": "operations",
    "name": "responsable por tarea",
    "rule": "cada tarea debe tener responsable definido",
    "check": "task.owner != null",
    "action": "reject",
    "severity": "high",
    "weight": 0.063,
    "enabled": true,
    "phase": "post",
    "description": "Sin owner, la tarea no existe"
  },
  {
    "id": "OPS_04",
    "category": "operations",
    "name": "deadline definido",
    "rule": "toda tarea debe tener deadline",
    "check": "task.deadline != null",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "Sin deadline, no hay urgencia"
  },
  {
    "id": "OPS_05",
    "category": "operations",
    "name": "revisi\u00f3n antes de deploy",
    "rule": "antes de deploy \u2192 revisi\u00f3n obligatoria",
    "check": "deploy.reviewed == true",
    "action": "require_confirmation",
    "severity": "high",
    "weight": 0.063,
    "enabled": true,
    "phase": "post",
    "description": "Nada va a prod sin review"
  },
  {
    "id": "OPS_06",
    "category": "operations",
    "name": "rollback plan definido",
    "rule": "todo deploy debe tener plan de rollback",
    "check": "deploy.rollback_plan != null",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "Si algo falla, c\u00f3mo volvemos"
  },
  {
    "id": "OPS_07",
    "category": "operations",
    "name": "log de ejecuci\u00f3n obligatorio",
    "rule": "toda ejecuci\u00f3n debe generar log",
    "check": "execution.log_created == true",
    "action": "reject",
    "severity": "high",
    "weight": 0.063,
    "enabled": true,
    "phase": "post",
    "description": "Sin log no hay auditor\u00eda"
  },
  {
    "id": "OPS_08",
    "category": "operations",
    "name": "sync Mac\u2194VPS activo",
    "rule": "si hay cambios locales \u2192 sync a VPS",
    "check": "local.changes_exist \u2192 sync.vps_updated == true",
    "action": "force_delegation",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "Delegar a sync agent para actualizar VPS"
  },
  {
    "id": "OPS_09",
    "category": "operations",
    "name": "m\u00ednimo 2 agentes activos",
    "rule": "el sistema debe tener al menos 2 agentes activos",
    "check": "agents.active_count >= 2",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "pre",
    "description": "1 agente = single point of failure"
  },
  {
    "id": "OPS_10",
    "category": "operations",
    "name": "backup diario verificado",
    "rule": "backup del d\u00eda debe existir y ser verificable",
    "check": "backup.today_exists == true && backup.verified == true",
    "action": "flag_for_review",
    "severity": "high",
    "weight": 0.063,
    "enabled": true,
    "phase": "pre",
    "description": "Sin backup verificable, no operamos"
  }
]