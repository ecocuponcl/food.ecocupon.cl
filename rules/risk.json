[
  {
    "id": "RISK_01",
    "category": "risk",
    "name": "no ejecutar sin validación si impacto alto",
    "rule": "si impacto es alto → requiere validación humana",
    "check": "impact.level == 'high' → human_validated == true",
    "action": "require_confirmation",
    "severity": "critical",
    "weight": 0.10,
    "enabled": true,
    "phase": "pre",
    "description": "Decisiones de alto impacto necesitan humano"
  },
  {
    "id": "RISK_02",
    "category": "risk",
    "name": "no credentials en output",
    "rule": "nunca incluir credenciales en output al usuario",
    "check": "output.contains_credentials == false",
    "action": "reject",
    "severity": "critical",
    "weight": 0.10,
    "enabled": true,
    "phase": "post",
    "description": "Fuga de credenciales = incidente de seguridad"
  },
  {
    "id": "RISK_03",
    "category": "risk",
    "name": "rate limiting respetado",
    "rule": "no exceder rate limits de APIs externas",
    "check": "api.calls_per_minute < api.rate_limit",
    "action": "reject",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "pre",
    "description": "Rate limit exceeded = API bloqueada"
  },
  {
    "id": "RISK_04",
    "category": "risk",
    "name": "data backup antes de cambios",
    "rule": "antes de cambios estructurales → backup",
    "check": "change.structural == true → backup.created == true",
    "action": "require_confirmation",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "pre",
    "description": "Sin backup, no hay recovery"
  },
  {
    "id": "RISK_05",
    "category": "risk",
    "name": "no single point of failure",
    "rule": "sistema crítico no debe depender de 1 componente",
    "check": "system.has_redundancy == true || system.is_non_critical == true",
    "action": "flag_for_review",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "SPOF = outage garantizado"
  },
  {
    "id": "RISK_06",
    "category": "risk",
    "name": "PII protegida",
    "rule": "datos personales deben estar encriptados",
    "check": "data.contains_pii == false || data.pii_encrypted == true",
    "action": "reject",
    "severity": "critical",
    "weight": 0.10,
    "enabled": true,
    "phase": "post",
    "description": "Ley de protección de datos: PII siempre encriptada"
  },
  {
    "id": "RISK_07",
    "category": "risk",
    "name": "audit trail completo",
    "rule": "toda acción debe dejar rastro de auditoría",
    "check": "action.audit_logged == true",
    "action": "reject",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "Sin audit trail, no hay compliance"
  },
  {
    "id": "RISK_08",
    "category": "risk",
    "name": "costo no excede presupuesto",
    "rule": "costo estimado no debe exceder presupuesto del proyecto",
    "check": "cost.estimated <= budget.allocated",
    "action": "require_confirmation",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "pre",
    "description": "Over budget = proyecto cancelado"
  },
  {
    "id": "RISK_09",
    "category": "risk",
    "name": "compliance legal verificado",
    "rule": "solución debe cumplir regulaciones locales",
    "check": "compliance.legal_checked == true",
    "action": "flag_for_review",
    "severity": "high",
    "weight": 0.07,
    "enabled": true,
    "phase": "post",
    "description": "SII, protección de datos, etc."
  },
  {
    "id": "RISK_10",
    "category": "risk",
    "name": "fallback definido",
    "rule": "si el sistema falla → debe existir fallback",
    "check": "system.fallback_defined == true",
    "action": "warn",
    "severity": "medium",
    "weight": 0.05,
    "enabled": true,
    "phase": "post",
    "description": "Plan B cuando el Plan A explota"
  }
]
