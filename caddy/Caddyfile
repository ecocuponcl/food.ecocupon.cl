# ═══════════════════════════════════════════════════════
# ECOCOUPON.CL (brand separada)
# ═══════════════════════════════════════════════════════

ecocupon.cl {
	root * /var/www/ecocupon-landing
	encode gzip
	file_server
}

www.ecocupon.cl {
	redir https://ecocupon.cl{uri}
}

food.ecocupon.cl {
	reverse_proxy http://127.0.0.1:8070
}

agent.food.ecocupon.cl {
	reverse_proxy http://127.0.0.1:9001
	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options nosniff
	}
}

api.ecocupon.cl {
	@root path /
	redir @root /health 302
	reverse_proxy http://127.0.0.1:9003
	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options nosniff
	}
}

