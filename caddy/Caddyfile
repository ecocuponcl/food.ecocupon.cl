# ── BOLT API ────────────────────────────────────────────
bolt-api.smarterbot.store {
	import tls_cf
    reverse_proxy http://127.0.0.1:9011
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options nosniff
    }
}


# flow.smarterbot.cl - Login con Twilio (RUT/SMS)
flow.smarterbot.cl {
    reverse_proxy localhost:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
    encode gzip
    log {
        output file /var/log/caddy/flow-cl-access.log
        level INFO
        format json
    }
}

# flow.smarterbot.store - Dashboard Operativo (Focalboard)
flow.smarterbot.store {
    reverse_proxy localhost:8001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
    encode gzip
    log {
        output file /var/log/caddy/flow-store-access.log
        level INFO
        format json
    }
}
