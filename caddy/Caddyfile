		X-Content-Type-Options nosniff
		X-Frame-Options "SAMEORIGIN"
	}
}

# ── n8n Automation ────────────────────────────────────
n8n.smarterbot.store, n8n.smarterbot.cl {
	reverse_proxy http://127.0.0.1:5678
}

# ── Dokploy (PaaS) ────────────────────────────────────
dokploy.smarterbot.store, dokploy.smarterbot.cl {
	reverse_proxy http://127.0.0.1:3000
}

# ── Bolt Dashboard (Streamlit) ────────────────────────
bolt.smarterbot.store {
	encode gzip
	reverse_proxy http://127.0.0.1:8502 {
		health_uri /
		health_interval 30s
		health_timeout 5s
	}
}

# ── LLM API (Motor puro) ─────────────────────────────
llm.smarterbot.store {
	reverse_proxy http://127.0.0.1:8000
}

# ── SmarterOS Main Portal + Status ────────────────────
os.smarterbot.store {
	@os_api path /revenue.json /balance.json /status.json /status /services /recovery.json /health /tenants.json /tenants /conversions.json /conversion /tower /tuning /rules /evaluate /scores /skus /brain.json
	handle @os_api {
		reverse_proxy http://127.0.0.1:8002
	}
	handle {
		root * /var/www/os-portal
		encode gzip
		file_server
	}
}

# ── API Router (BOLT Controlled) ──────────────────────
api.smarterbot.store {
	encode gzip

	@n8n path /v1/flow/*
	handle @n8n {
		reverse_proxy http://127.0.0.1:5678
	}

	@bolt path /api/bolt/*
	handle @bolt {
		reverse_proxy http://127.0.0.1:9011
	}

	@uf path /api/uf/* /api/uf
	handle @uf {
		reverse_proxy http://127.0.0.1:8005
	}

	@agent path /v1/status* /v1/health*
	handle @agent {
		reverse_proxy http://127.0.0.1:8002
	}

	handle {
		respond "BOLT API v1.0 — 50 rules active" 200
	}

	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options nosniff
	}
}

# ── API Docs (static) ─────────────────────────────────
docs.smarterbot.store {
